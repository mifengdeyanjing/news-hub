{
  "name": "news-hub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": { "node": ">=18" },
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite\" \"node server/index.js\"",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "daily": "bash scripts/open-local.sh",
    "stop": "lsof -ti:3001 -ti:5173 | xargs kill -9 2>/dev/null; rm -f .news-hub.pid"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@tanstack/react-query": "^5.80.7",
    "hono": "^4.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.10",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "tailwindcss": "^4.1.10",
    "vite": "^6.3.5"
  }
}
